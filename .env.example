# ── Snowflake ─────────────────────────────────────────
# Sign up for free trial: https://signup.snowflake.com/
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=parsely
SNOWFLAKE_ROLE=parsely_pipeline_role

# ── Databricks ────────────────────────────────────────
# Sign up for Community Edition: https://community.cloud.databricks.com/
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_access_token

# ── App Settings ──────────────────────────────────────
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
